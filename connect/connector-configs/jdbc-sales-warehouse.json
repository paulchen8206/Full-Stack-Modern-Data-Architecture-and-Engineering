{
  "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
  "tasks.max": "1",
  "topics": "sales_order,sales_order_line_item,customer_sales",
  "value.converter": "org.apache.kafka.connect.json.JsonConverter",
  "value.converter.schemas.enable": "true",
  "connection.url": "jdbc:postgresql://realtime-dev-realtime-app-postgres:5432/analytics",
  "connection.user": "analytics",
  "connection.password": "analytics",
  "table.name.format": "landing.${topic}",
  "insert.mode": "insert",
  "auto.create": "true",
  "auto.evolve": "true",
  "batch.size": "3000",
  "delete.enabled": "false",
  "pk.mode": "none",
  "errors.tolerance": "all",
  "errors.log.enable": "true",
  "errors.log.include.messages": "true",
  "transforms": "castNumbers",
  "transforms.castNumbers.type": "org.apache.kafka.connect.transforms.Cast$Value",
  "transforms.castNumbers.spec": "orderTotal:float64,unitPrice:float64,lineTotal:float64,totalSpent:float64",
  "consumer.override.auto.offset.reset": "latest",
  "quote.sql.identifiers": "never"
}
