{
  "name": "dbz-mysql-mdm",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mdm-source",
    "database.port": "3306",
    "database.user": "root",
    "database.password": "mdmroot",
    "database.server.id": "5401",
    "topic.prefix": "mysql
    "database.include.list": "mdm",
    "table.include.list": "mdm.customer360,mdm.product_master,mdm.date",
    "include.schema.changes": "false",
    "snapshot.mode": "initial",
    "decimal.handling.mode": "string",
    "time.precision.mode": "connect",
    "schema.history.internal": "io.debezium.storage.kafka.history.KafkaSchemaHistory",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "schema-changes.mdm"
  }
}
