# syntax=docker/dockerfile:1
FROM alpine:3.19

# Install bash, curl, and jq
RUN apk add --no-cache bash curl jq

# Copy the schema registration script into the image
COPY scripts/docker-register-schemas.sh /scripts/docker-register-schemas.sh
RUN chmod +x /scripts/docker-register-schemas.sh

# Copy schemas directory (optional, if needed by the script)
COPY schemas /schemas

WORKDIR /

ENTRYPOINT ["/scripts/docker-register-schemas.sh"]
